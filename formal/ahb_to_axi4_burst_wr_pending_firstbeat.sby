[tasks]
bmc
cover

[options]
bmc:   mode bmc
bmc:   depth 30
cover: mode cover
cover: depth 50

[engines]
bmc: abc bmc3
# bmc: smtbmc --progress --nopresat  z3
cover: smtbmc --progress --dumpsmt2 z3 timeout=60000 rlimit=20000000
# cover: smtbmc z3

[script]
read_verilog -formal -sv ahb_to_axi4_burst_formal_tap.sv
read_verilog -formal -sv ahb_to_axi4_burst_wr_pending_firstbeat_fv.sv
prep -top ahb_to_axi4_burst_wr_pending_firstbeat_fv

[files]
rtl/ahb_to_axi4_burst_formal_tap.sv
formal/ahb_to_axi4_burst_wr_pending_firstbeat_fv.sv
